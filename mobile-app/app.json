{
  "expo": {
    "name": "Company Monitor",
    "slug": "company-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.companymonitor",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "We need permission to send you alerts about company changes you're monitoring."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourcompany.companymonitor",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      "expo-font"
    ],
    "scheme": "companymonitor",
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
